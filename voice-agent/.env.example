# Local development env for the voice agent. Copy to `.env` (which is
# gitignored). Modal Production reads the same vars from Modal Secrets,
# NOT from this file — see README.md.

# Sarvam (https://dashboard.sarvam.ai)
SARVAM_API_KEY=

# OpenAI (same key as the Next.js app uses for GPT-4o-mini chat completions)
OPENAI_API_KEY=

# Supabase — only project URL + anon key go on the client. JWT_SECRET stays
# server-side. URL + anon key match the values in the repo-root .env.example.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Which user the voice agent acts as during local development. Same Supabase
# user UUID as ALEXA_HOUSEHOLD_USER_ID in the repo-root .env.example.
# In production this comes from the authenticated session, not from env.
VOICE_AGENT_DEV_USER_ID=
