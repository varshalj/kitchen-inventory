# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (required for AI features: scan, meal plan, suggestions)
OPENAI_API_KEY=sk-...

# Encryption key for user-provided API keys (required if using per-user AI keys)
KMS_MASTER_KEY=your-random-secret-key

# Email ingestion callback secret (authenticates Relay.app webhook calls)
EMAIL_CALLBACK_SECRET=your-email-callback-secret
