# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Supabase JWT signing secret (Project Settings → API → JWT Secret).
# Used by server-side voice/webhook handlers to mint user-scoped sessions.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Alexa skill backend (optional — only set when wiring up the Alexa skill)
# - HOUSEHOLD_USER_ID: the Supabase user uuid every Alexa voice request acts as
# - SKILL_ID: the Alexa Skill ID (amzn1.ask.skill...) for app-id binding
ALEXA_HOUSEHOLD_USER_ID=
ALEXA_SKILL_ID=

# OpenAI (required for AI features: scan, meal plan, suggestions)
OPENAI_API_KEY=sk-...

# Encryption key for user-provided API keys (required if using per-user AI keys)
KMS_MASTER_KEY=your-random-secret-key

# Email ingestion callback secret (authenticates Relay.app webhook calls)
EMAIL_CALLBACK_SECRET=your-email-callback-secret

# Swiggy MCP OAuth integration (optional — leave unset to derive the redirect
# URI from the request host, which Just Works for localhost dev and prod alike).
# Set explicitly only if your deploy is behind a proxy that mangles the host
# header or if you need to pin a specific redirect URI for Swiggy whitelisting.
# Example for prod: SWIGGY_OAUTH_REDIRECT_URI=https://kitchen-inventory.vercel.app/api/integrations/swiggy/callback
SWIGGY_OAUTH_REDIRECT_URI=
